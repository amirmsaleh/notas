@book{ CarlGustavJung367,
    title = "Mysterium Coniunctionis - 14/3",
    title_sort = "Mysterium Coniunctionis - 14/3",
    author_sort = "Jung, Carl Gustav",
    author = "Carl Gustav Jung",
    note = "Este volume expõe e comenta um texto alquímico, escrito com certeza por um clérigo, provavelmente no século XIII; expõe-se aí um estado de espírito extremamente singular, no qual cristianismo e alquimia se interpenetram reciprocamente. Tenta ele servir-se da mística do Cântico dos Cânticos para fundir as ideias aparentemente heterogêneas, procedentes do cristianismo e da filosofia da natureza, e lançar esse fluxo na forma de um hino. O texto é conhecido como Aurora Consurgens [A Aurora que surge] e desde long data vem sendo atribuído a Tomás de Aquino.[...] A alquimia significava muitíssimo para um Alberto Magno, um Roger Bacon e também para um Tomás de Aquino. Aurora Consurgens procura unir a concepção cristã e a alquímica; por isso é que o escolhi como exemplo de uma discussão esclarecedora entre o espírito cristão da época medieval e a filosofia da alquimia.
",
    cover = "/home/amir/Biblioteca do calibre/Carl Gustav Jung/Mysterium Coniunctionis - 14\_3 (367)/cover.jpg",
    formats = "epub",
    calibreid = "367",
    isbn = "0000000000000",
    library_name = "Biblioteca do calibre",
    year = "2021",
    month = "fev",
    publisher = "Vozes",
    rating = "10",
    volume = "1",
    series = "Obras Competas",
    size = "708072 octets",
    tags = "Psicologia Analítica",
    timestamp = "2022-09-04",
    uuid = "2cd44086-007a-4c1a-b737-83d6ebd0e718",
    language = "por",
    identifiers = "isbn:0000000000000" }

@book{ CarlGustavJung368,
    title = "Aion: Estudos sobre o simbolismo do si-mesmo - 9/2",
    title_sort = "Aion: Estudos sobre o simbolismo do si-mesmo - 9/2",
    author_sort = "Jung, Carl Gustav",
    author = "Carl Gustav Jung",
    note = "Aion é uma variante para designar a era cristã que encontra seu término na parusia de Cristo e no aparecimento do Anticristo. C. G. Jung, servindo-se dos símbolos cristãos, gnósticos e alquimistas do si-mesmo, estuda em Aion as mudanças da situação psíquica dentro do Éon cristão. O ponto central de todas as reflexões é a tentativa de esclarecer e ampliar o arquétipo do si-mesmo e relacioná-lo com a figura tradicional de Cristo. Decisivo é que Cristo é visto como símbolo da totalidade universal que reúne em si todas as características de um arquétipo. **
",
    cover = "/home/amir/Biblioteca do calibre/Carl Gustav Jung/Aion\_ Estudos sobre o simbolismo do si-mesmo - 9\_2 (368)/cover.jpg",
