@misc{ JeanPaulSartre218,
    title = "A Transcendência do Ego",
    title_sort = "Transcendência do Ego, A",
    author_sort = "Sartre, Jean Paul",
    author = "Jean Paul Sartre",
    note = "A Transcendência do Ego é considerada a primeira obra propriamente filosófica de Jean-Paul Sartre. Foi escrita em 1934 e publicada em 1936, alguns anos antes, portanto, de seu magistral O Ser e o Nada, que o consagraria entre os grandes nomes da filosofia contemporânea e, particularmente, do Existencialismo. Aqui Sartre dá início ao seu projeto filosófico, combatendo as teses da presença formal e material do Eu na consciência, defendidas por Kant e Husserl, respectivamente.
",
    cover = "/home/amir/Biblioteca do calibre/Jean Paul Sartre/A Transcendencia do Ego (218)/cover.jpg",
    formats = "azw3, epub, original_epub",
    calibreid = "218",
