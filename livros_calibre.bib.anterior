@book{ NADAIB.269,
    title = "Progresso e moral na filosofia da história de Kant",
    title_sort = "Progresso e moral na filosofia da história de Kant",
    author_sort = "NADAI, B.",
    author = "NADAI, B.",
    note = "Podemos discernir algum padrão racional de desenvolvimento histórico em meio ao constante vai e vem dos fatos e acontecimentos? Será que podemos admitir a ideia de que nós, seres humanos, estamos em constante progresso em direção a um mundo melhor? Em que bases e com quais pressupostos podemos dizer que a humanidade progride moralmente? Para além do desenvolvimento civilizatório e das instituições políticas mundo afora, podemos encontrar algum progresso das relações humanas baseadas no princípio de que devemos obedecer apenas leis que nós mesmos estabelecemos? Este livro procura responder a tais perguntas por meio da reconstrução da ideia de uma história filosófica formulada por Immanuel Kant. O leitor está convidado a percorrer conosco algumas das principais obras deste autor, para que possamos nos posicionar sobre o assunto! Adiantamos que, diferentemente do que muitos manuais ensinam, a imagem que emerge aqui é a de um Kant menos formalista, mais atento às condições de realização da razão no mundo.
",
    cover = "/home/amir/Biblioteca do calibre/NADAI, B\_/Progresso e moral na filosofia da historia de Kant (269)/cover.jpg",
    formats = "azw3, epub",
    calibreid = "269",
    library_name = "Biblioteca do calibre",
    year = "2017",
    month = "jul",
    publisher = "Editora UFABC",
    volume = "1",
    size = "1069884 octets",
    tags = "Kant, Filosofia da História, Moral",
    timestamp = "2021-07-24",
    uuid = "6956f5d3-d4aa-4730-95ad-00d921c2527f",
    language = "por" }

