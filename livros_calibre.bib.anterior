@book{ EloisaM.D.Penna415,
    title = "Epistemologia e método Jung",
    title_sort = "Epistemologia e método Jung",
    author_sort = "Penna, Eloisa M. D.",
    author = "Eloisa M. D. Penna",
    note = "O que nós clínicos fazíamos, de um certo modo intuitivo, na Universidade, mostrava grandes desafios. Qual é o método junguiano? Isto é, há um método junguiano? Como orientar nossos alunos em suas pesquisas sem a forma mais objetiva e descritiva de um método? Aqui está o valor deste livro e de sua autora. Eloisa Penna, há anos lecionando na PUC-SP, onde há uma equipe de professores que seguem a orientação da psicologia analítica, fornece uma base epistemológica segura para todos ao refletir sobre essas questões e extrair da obra junguiana os princípios básicos que podem guiar um trabalho acadêmico. É uma obra original e bastante elogiada internacionalmente.
",
    cover = "/home/amir/Biblioteca do calibre/Eloisa M. D. Penna/Epistemologia e metodo Jung (415)/cover.jpg",
    formats = "epub",
    calibreid = "415",
    library_name = "Biblioteca do calibre",
    year = "2014",
    month = "mai",
    publisher = "Educ - Editora da PUC-SP",
    volume = "1",
