@book{ BEZERRACM.430,
    title = "Inovações tecnológicas e a complexidade do sistema econômico",
    title_sort = "Inovações tecnológicas e a complexidade do sistema econômico",
    author_sort = "BEZERRA, CM.",
    author = "BEZERRA, CM.",
    note = "O objetivo deste trabalho é analisar como o processo de inovações tecnológicas é tratado pela Teoria dos Sistemas Complexos. A abordagem neoclássica tradicional, ao partir de pressupostos bastante restritivos sobre os agentes e os mercados, não é capaz de fornecer explicações plausíveis aos vários problemas econômicos da vida real. Ao desconsiderar a dinâmica dos fenômenos econômicos, essa abordagem foi incapaz de incorporar os aspectos do processo de inovação e mudança tecnológica. A abordagem evolucionária, nesse sentido, ao considerar a racionalidade limitada, incerteza e heterogeneidade presente em ambientes que exibem inovação, foi capaz de fornecer um tratamento mais próximo da realidade. A inovação é, então, entendida como uma mudança descontínua que altera as condições estruturais gerando desenvolvimento, progresso e evolução no sistema. Já abordagem dos sistemas complexos, ao apresentar um arcabouço não reducionista e que se fundamenta sobre uma perspectiva evolucionária e sistêmica, concebe a economia como um sistema composto por agentes heterogêneos que interagem entre si. Apesar do ambiente de incerteza nas decisões tomadas, os agentes procuram se adaptar às informações recebidas do meio e se auto-organizarem gerando com isso novos padrões de auto-ordenamento e estruturas emergentes. A modelagem, nesse sentido, tem por principal objetivo descobrir as propriedades emergentes resultantes da interação entre os agentes no sistema. Por fim chega-se a conclusão de que as inovações tecnológicas apresentaram resultados mais satisfatórios e mais condizentes quando analisadas dentro dessa perspectiva agent-based.
",
    cover = "/home/amir/Biblioteca do calibre/BEZERRA, CM\_/Inovacoes tecnologicas e a complexidade do sistema economico (430)/cover.jpg",
    formats = "epub",
    calibreid = "430",
    isbn = "978-85-7983-089-1",
    library_name = "Biblioteca do calibre",
    year = "2010",
    month = "out",
    publisher = "Editora UNESP",
    volume = "1",
    size = "264954 octets",
    tags = "Economia, Economia evolutiva, Inovações tecnológicas, Desenvolvimento econômico",
    timestamp = "2025-10-05",
    uuid = "c050abee-d385-49ed-9286-0cb8539ef670",
    language = "por",
    identifiers = "uri:http://books.scielo.org/id/36rwg/epub/bezerra-9788579830891.epub,isbn:9788579830891" }

@book{ SylviaIasulaitis431,
    title = "Estudos sociopolíticos da Inteligência Artificial",
    title_sort = "Estudos sociopolíticos da Inteligência Artificial",
    author_sort = "Iasulaitis, Sylvia \& Silveira, Amadeu da",
    author = "Sylvia Iasulaitis and Amadeu da Silveira",
    note = "Com o avanço da Inteligência Artificial (IA) e a proliferação de suas aplicações em diversos âmbitos, os atores inteligentes não humanos estão, cada vez mais, tornando-se parte da sociedade contemporânea e impulsionando transformações em diversos aspectos da organização e da realidade social. As disciplinas científicas que estudam o social, particularmente as Ciências Sociais, podem dar sua contribuição para compreensão dos aspectos específicos da digitalização na vida cotidiana, que é um domínio onde a Inteligência Artificial desempenha papel crescente. Nesta coletânea, o intuito é apresentar um conjunto de textos que refletem sobre a Inteligência Artificial a partir de uma perspectiva eminentemente sociológica, partindo-se da concepção de que a IA consiste em um fenômeno social, sendo, ela própria, um ator social não humano.
",
    cover = "/home/amir/Biblioteca do calibre/Sylvia Iasulaitis/Estudos sociopoliticos da Inteligencia Artificial (431)/cover.jpg",
    formats = "epub",
    calibreid = "431",
    library_name = "Biblioteca do calibre",
    year = "2025",
    month = "dez",
    publisher = "EDUEPB",
    volume = "1",
    size = "2063626 octets",
    tags = "COMPUTERS / Artificial Intelligence / Computer Vision \& Pattern Recognition, Inteligência Artificial, Sociologia da Inteligência Artificial, Capitalismo Digital, Recursos da Inteligência Artificial, Aplicações da Inteligência Artificial, Tecnologia e sociedade, Ciências sociais, Digitalização, Sociedade contemporânea, Atores não humanos, Transformações sociais, Fenômenos sociotecnológicos, Impacto tecnológico, Automação, Ética da Inteligência Artificial, Interação humano-máquina, Teoria social, Cultura digital, Tecnologia emergente, Sociedade em rede",
    timestamp = "2025-12-24",
    uuid = "7f339637-b6a9-44d2-9ff5-910901626e60",
    language = "por" }

