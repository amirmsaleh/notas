@book{ AntonioIanniSegatto161,
    title = "Wittgenstein e o problema da harmonia entre pensamento e realidade",
    title_sort = "Wittgenstein e o problema da harmonia entre pensamento e realidade",
    author_sort = "Segatto, Antônio Ianni",
    author = "Antônio Ianni Segatto",
    note = "Esta obra discorre sobre o problema da vinculação entre pensamento (ou linguagem) e realidade tal como ele é formulado e discutido por Ludwig Wittgenstein, especificamente em sua produção filosófica a partir da década de 1930. Antonio Segatto examina o modo como o filósofo concebe aquilo que chamou de “harmonia entre pensamento e realidade” e como enfrenta as questões que giram em torno dela.
