@book{ CarlGustavJung273,
    title = "Estudos Alquímicos 13",
    title_sort = "Estudos Alquímicos 13",
    author_sort = "Jung, Carl Gustav",
    author = "Carl Gustav Jung",
    note = "O décimo terceiro volume da coleção Obra Completas de C. G. Jung apresenta a concordância entre os símbolos do mundo das imagens do inconsciente e os símbolos da alquimia. Jung mostrou que as projeções alquimistas constituíam apenas um caso especial o pensamento em geral, e que também o processo da individuação se parecia com o caminho que os alquimistas já haviam trilhado a seu modo sem sua época. Assim, o autor não trouxe à luz do dia aspectos ocultos da ciência alquímica, mas também {"}o correspondente histórico à psicologia do inconsciente{"}.
",
    cover = "/home/amir/Biblioteca do calibre/Carl Gustav Jung/Estudos Alquimicos 13 (273)/cover.jpg",
    formats = "azw3, epub",
    calibreid = "273",
