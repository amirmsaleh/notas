@book{ CarlGustavJung365,
    title = "Mysterium Coniunctionis - 14/1",
    title_sort = "Mysterium Coniunctionis - 14/1",
    author_sort = "Jung, Carl Gustav",
    author = "Carl Gustav Jung",
    note = "Nasceu a presente obra do conhecimento que tinha C. G. Jung de que uma grande parte da problemática do homem moderno já se antecipa naquilo que os alquimistas chamavam de {"}arte{"} ou o seu {"}processo{"}. Na verdade, não viram bem que estavam lidando com um evento psíquico, embora alguns deles tenham pressentido o momento religioso ou filosófico aí existente. O autor procura oferecer um quadro da problemática da alquimia filosófica, abordando seu problema central: a unificação ou superação dos opostos. Consegue desta forma demonstrar {"}que o mundo alquímico dos símbolos está na mais viva correlação com as mais novas experiências e conhecimentos da psicologia do inconsciente{"}. Ao perscrutar esses símbolos, Jung traz à luz a relação que eles têm com os processos existentes no inconsciente humano. Estes podem manifestar-se nos sonhos, nas fantasias espontâneas ou nas alucinações. Mas também servem de fundamento igualmente à obra de arte e às religiões. **
",
    cover = "/home/amir/Biblioteca do calibre/Carl Gustav Jung/Mysterium Coniunctionis - 14\_1 (365)/cover.jpg",
    formats = "epub",
    calibreid = "365",
    isbn = "978-85-3265-841-8",
    library_name = "Biblioteca do calibre",
    year = "2018",
    month = "jun",
    publisher = "Vozes",
    rating = "10",
    volume = "1",
    series = "Obras Competas",
    size = "619127 octets",
    tags = "Psicologia, Psicologia Analítica, Alquimia",
    timestamp = "2022-09-04",
    uuid = "de2ab848-49db-4231-bdd8-f344c2a469bd",
    language = "por",
    identifiers = "google:k1BgDwAAQBAJ,amazon:B07DTJDSV2,isbn:9788532658418" }

@book{ CarlGustavJung366,
    title = "Mysterium Coniunctionis - 14/2",
    title_sort = "Mysterium Coniunctionis - 14/2",
    author_sort = "Jung, Carl Gustav",
    author = "Carl Gustav Jung",
    note = "Nasceu a presente obra do conhecimento que tinha C. G. Jung de que uma grande parte da problemática do homem moderno já se antecipa naquilo que os alquimistas chamavam de {"}arte{"} ou o seu {"}processo{"}. Na verdade, não viram bem que estavam lidando com um evento psíquico, embora alguns deles tenham pressentido o momento religioso ou filosófico aí existente. O autor procura oferecer um quadro da problemática da alquimia filosófica, abordando seu problema central: a unificação ou superação dos opostos. Consegue desta forma demonstrar {"}que o mundo alquímico dos símbolos está na mais viva correlação com as mais novas experiências e conhecimentos da psicologia do inconsciente{"}. Ao perscrutar esses símbolos, Jung traz à luz a relação que eles têm com os processos existentes no inconsciente humano. Estes podem manifestar-se nos sonhos, nas fantasias espontâneas ou nas alucinações. Mas também servem de fundamento igualmente à obra de arte e às religiões.
