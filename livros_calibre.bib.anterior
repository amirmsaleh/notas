@book{ CarlGustavJung272,
    title = "Símbolos da transformação",
    title_sort = "Símbolos da transformação",
    author_sort = "Jung, Carl Gustav",
    author = "Carl Gustav Jung",
    note = "Revisão do livro Transformações e símbolos da libido, que marcou a separação entre Jung e Sigmund Freud. Traz uma nova abordagem à teoria da libido e à questão do incesto, através dos mitos onde o herói tenta libertar-se da figura materna. O autor lança mão de inúmeros paralelos mitológicos para compreender as fantasias de um caso de esquizofrenia. **
",
    cover = "/home/amir/Biblioteca do calibre/Carl Gustav Jung/Simbolos da transformacao (272)/cover.jpg",
