@book{ CarlGustavJung308,
    title = "Civilização em transição - 10/3",
    title_sort = "Civilização em transição - 10/3",
    author_sort = "Jung, Carl Gustav",
    author = "Carl Gustav Jung",
    note = "Coletânea de ensaios que giram em torno das relações entre o psiquismo e acontecimentos importantes da civilização. O homem moderno, o homem arcaico, a mulher, o bem e o mal, são alguns dos temas estudados. Os capítulos sobre o bem e o mal e sobre a função psicológica da consciência são importantes e indispensáveis para se entender a concepção de Jung, que afirma ser a crise da civilização uma crise sobretudo moral. Também os capítulos que narram a visita de Jung aos Estados Unidos e à Índia são interessantes do ponto de vista dos conceitos de raça, cor, sociedade etc. **
",
    cover = "/home/amir/Biblioteca do calibre/Carl Gustav Jung/Civilizacao em transicao - 10\_3 (308)/cover.jpg",
    formats = "azw3, epub",
